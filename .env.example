# =============================================================================
# MindOS Docker 部署环境变量模板
# 复制此文件为 .env 并填写实际值
#   cp .env.example .env
#
# AI 配置已移至 config.example.json → config.json 管理
# =============================================================================

# ── Builder 镜像版本标签 ──
# 构建 Builder 时的版本号，与 mindos 产品版本保持一致
MINDOS_VERSION=1.0.9

# ── 服务端口（可选，有默认值） ──
# MINDOS_WEB_PORT=3456
# MINDOS_MCP_PORT=8781

# ── 日志配置（可选） ──
# LOG_LEVEL: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
# PRETTY_LOGS: Docker logs 中启用彩色格式化输出
PRETTY_LOGS=true

# ── 可选：安全认证（也可在 config.json 中设置） ──
# AUTH_TOKEN=your-secret-token